    {
      "id": 10,
      "type": "stat",
      "title": "Ingest freshness by component (min since last line)",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 4
      },
      "description": "Minutes since the most recent log line for each component. Green < 5m, orange < 30m, red beyond. A wedged tailer (one component stops flowing while the others advance — see README \"Tailer wedge\") turns its tile red within minutes. The [24h] lookback keeps a long-wedged component visible as a growing red value instead of dropping it.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 30
              }
            ]
          },
          "mappings": [],
          "links": [
            {
              "title": "Ion Live Logs",
              "url": "/d/ion-logs",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": true
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "(vector(${__to:date:seconds}) - on() group_right() max by (component) (max_over_time({component=~\".+\"} | label_format ts_unix=\"{{ __timestamp__ | unixEpoch }}\" | unwrap ts_unix [24h]))) / 60",
          "queryType": "instant",
          "refId": "A",
          "__ionClass": "instant",
          "legendFormat": "{{component}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Log volume by component",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "maxDataPoints": 2000,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (component) (rate({component=~\".+\"}[1m]))",
          "queryType": "range",
          "refId": "A",
          "__ionClass": "windowed-stat",
          "legendFormat": "{{component}}"
        }
      ]
    },
