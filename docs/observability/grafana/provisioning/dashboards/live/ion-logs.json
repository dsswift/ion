        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "quantile_over_time(0.5, {service_name=\"ion-telemetry\", kind=\"provider.ttft\"} | json | unwrap payload_ttft_ms [$__interval]) by ()",
          "queryType": "range",
          "refId": "A",
          "__ionClass": "windowed-stat",
          "legendFormat": "TTFT p50"
        }
      ]
