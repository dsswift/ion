    {
      "id": 15,
      "type": "table",
      "title": "Sub-agent tax by session (range)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 43
      },
      "description": "Sub-agent tax by session. dispatch.agent (a span) keys session under payload_session_id; run.complete keys it under context_session_id. The dispatch series is aliased to context_session_id so the join aligns. Ratio = sub-agent cost / total session cost.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "context_session_id"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open forensics",
                    "url": "/d/ion-forensics/ion-conversation-forensics?var-session=${__value.raw}&${__url_time_range}"
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "footer": {
          "show": false
        },
        "sortBy": [
          {
            "displayName": "sub-agent cost",
            "desc": true
          }
        ]
      },
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "context_session_id",
            "mode": "outer"
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "sub-agent share",
            "mode": "binary",
            "binary": {
              "left": "sub-agent cost",
              "right": "total cost",
              "operator": "/"
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #A": "sub-agent cost",
              "Value #B": "total cost"
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "label_replace(sum by (payload_session_id) (sum_over_time({service_name=\"ion-telemetry\", kind=\"dispatch.agent\"} | json | unwrap payload_cost_usd [$__range])), \"context_session_id\", \"$1\", \"payload_session_id\", \"(.+)\")",
          "queryType": "instant",
          "refId": "A",
          "__ionClass": "instant",
          "legendFormat": "sub-agent cost"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (context_session_id) (sum_over_time({service_name=\"ion-telemetry\", kind=\"run.complete\"} | json | unwrap payload_run_cost_usd [$__range]))",
          "queryType": "instant",
          "refId": "B",
          "__ionClass": "instant",
          "legendFormat": "total cost"
        }
      ]
    },
    {
