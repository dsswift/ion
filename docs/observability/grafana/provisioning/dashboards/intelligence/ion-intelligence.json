      },
      "maxDataPoints": 2000,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (payload_dispatch_depth) (count_over_time({service_name=\"ion-telemetry\", kind=\"dispatch.agent\"} | json [$__interval]))",
          "queryType": "range",
          "refId": "A",
          "__ionClass": "accumulation",
          "legendFormat": "depth {{payload_dispatch_depth}}"
