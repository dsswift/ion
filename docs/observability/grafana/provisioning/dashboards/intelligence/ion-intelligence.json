    {
      "id": 11,
      "type": "timeseries",
      "title": "Cache savings trend (weekly)",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 45
      },
      "description": "Total dollars saved by prompt caching per week. A flat or declining line means caching is not being leveraged — look at session length and repeat-prefix patterns. Phase-B event required.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "maxDataPoints": 2000,
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "fillOpacity": 20,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(sum_over_time({service_name=\"ion-telemetry\", kind=\"cache.savings\"} | json | unwrap payload_savings_usd [$__interval]))",
          "queryType": "range",
          "refId": "A",
          "__ionClass": "accumulation",
          "legendFormat": "cache savings (USD)"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Tokens reclaimed by compaction (weekly)",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 45
      },
      "description": "Tokens freed by context compaction per week, split by trigger type (automatic vs manual). This is the efficiency dividend of the compaction subsystem. Phase-B event required.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "maxDataPoints": 2000,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (payload_trigger) (sum_over_time({service_name=\"ion-telemetry\", kind=\"compaction\"} | json | unwrap payload_tokens_reclaimed [$__interval]))",
          "queryType": "range",
          "refId": "A",
          "__ionClass": "accumulation",
          "legendFormat": "{{payload_trigger}}"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Thrash trend (daily)",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 45
      },
      "description": "Tool failure rate: failures divided by total tool executions, per interval. The long-run quality health line. A rising trend means tooling reliability is degrading relative to usage.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "maxDataPoints": 2000,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "stacking": {
              "mode": "none"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.05
              },
              {
                "color": "red",
                "value": 0.15
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "transformations": [
        {
          "id": "calculateField",
          "options": {
            "alias": "failure rate",
            "mode": "binaryOperation",
            "binary": {
              "left": "failures",
              "right": "executions",
              "operator": "/"
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({service_name=\"ion-telemetry\", kind=\"tool.failure\"} | json [$__interval]))",
          "queryType": "range",
          "refId": "A",
          "__ionClass": "accumulation",
          "legendFormat": "failures"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({service_name=\"ion-telemetry\", kind=\"tool.execute\"} [$__interval]))",
          "queryType": "range",
          "refId": "B",
          "__ionClass": "accumulation",
          "legendFormat": "executions"
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": [
    "ion",
    "intelligence"
  ],
  "templating": {
    "list": [
      {
        "name": "model",
        "label": "Model",
        "type": "textbox",
        "description": "Filter by model name. Accepts regex. Default matches all.",
        "query": ".+",
        "current": {
          "value": ".+"
        },
        "hide": 0
      }
    ]
  },
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "Ion Product Intelligence",
  "uid": "ion-intel",
  "version": 3
}
