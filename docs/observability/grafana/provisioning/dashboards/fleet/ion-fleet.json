          "refId": "A",
          "__ionClass": "accumulation"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Fleet errors",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 4
      },
      "description": "Telemetry events carrying a non-empty payload_error. Ops-log ERROR lines carry no host identity, so this is the per-host error signal.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum (count_over_time({service_name=\"ion-telemetry\"} | json | host=~\"$host\" | payload_error!=\"\" [$__range]))",
          "queryType": "instant",
          "refId": "A",
          "__ionClass": "accumulation"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Host last-seen (min)",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 4
      },
      "description": "Minutes since the most recent telemetry event per host. Fixed 24h lookback (liveness detector): a host whose engine stopped reporting climbs while the others stay near zero.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 60
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": true
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "(vector(${__to:date:seconds}) - on() group_right() max by (host) (max_over_time({service_name=\"ion-telemetry\"} | json | host=~\"$host\" | label_format ts_unix=\"{{ __timestamp__ | unixEpoch }}\" | unwrap ts_unix [24h]))) / 60",
          "queryType": "instant",
          "refId": "A",
          "__ionClass": "instant",
          "legendFormat": "{{host}}"
        }
      ]
    },
