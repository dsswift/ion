    {
      "id": 6,
      "type": "timeseries",
      "title": "Denial rate by deciding layer",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "description": "Which layer is doing the denying: static rules, dangerous-command patterns, or the LLM classifier. Classifier denials are expensive; rules are cheap. Watch for classifier share growing as rules fail to keep up.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "maxDataPoints": 2000,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (payload_deciding_layer) (count_over_time({service_name=\"ion-telemetry\", kind=\"permission.decision\"} | json | payload_decision=\"deny\" [$__interval]))",
          "queryType": "range",
          "refId": "A",
          "__ionClass": "accumulation",
          "legendFormat": "{{payload_deciding_layer}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Decision latency p99: classifier vs rules",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "description": "The gap between these two lines is the cost of asking a model instead of matching a rule. Classifier cache hits show as sub-millisecond outliers.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "maxDataPoints": 2000,
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "quantile_over_time(0.99, {service_name=\"ion-telemetry\", kind=\"permission.decision\"} | json | payload_deciding_layer=\"llm_classifier\" | unwrap payload_decision_latency_ms [$__interval]) by ()",
          "queryType": "range",
          "refId": "A",
          "__ionClass": "windowed-stat",
          "legendFormat": "classifier p99"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "quantile_over_time(0.99, {service_name=\"ion-telemetry\", kind=\"permission.decision\"} | json | payload_deciding_layer!=\"llm_classifier\" | unwrap payload_decision_latency_ms [$__interval]) by ()",
          "queryType": "range",
          "refId": "B",
          "__ionClass": "windowed-stat",
          "legendFormat": "rules p99"
        }
      ]
    },
