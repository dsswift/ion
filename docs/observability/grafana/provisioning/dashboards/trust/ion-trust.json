          "expr": "sum(count_over_time({service_name=\"ion-telemetry\", kind=\"permission.decision\"} | json | payload_decision=\"deny\" [$__range]))",
          "queryType": "instant",
          "refId": "A",
          "__ionClass": "accumulation"
