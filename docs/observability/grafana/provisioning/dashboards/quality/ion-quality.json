{
  "annotations": {
    "list": [
      {
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "enable": true,
        "hide": false,
        "iconColor": "blue",
        "name": "Compaction",
        "titleFormat": "compaction: {{payload_trigger}} reclaimed {{payload_tokens_reclaimed}} tokens",
        "type": "logs",
        "rawQuery": "{service_name=\"ion-telemetry\", kind=\"compaction\"} | json"
      },
      {
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "enable": true,
        "hide": false,
        "iconColor": "red",
        "name": "Extension respawn",
        "titleFormat": "respawn: {{payload_extension}} attempt {{payload_attempt}}/{{payload_budget_max}}",
        "type": "logs",
